{
  "manifest_version": 3,
  "name": "FSB v0.9",
  "version": "0.9",
  "description": "FSB - Universal AI-powered browser automation assistant with multi-model support",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "windows",
    "sidePanel",
    "debugger",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "Assets/icon16.png",
    "48": "Assets/icon48.png",
    "128": "Assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "Assets/icon16.png",
      "48": "Assets/icon48.png",
      "128": "Assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["automation-logger.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html"
}